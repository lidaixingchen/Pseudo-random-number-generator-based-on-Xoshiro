# Doxyfile — RandX API 参考文档配置
# CI 构建时自动从 CMakeLists.txt 提取 VERSION 覆盖 PROJECT_NUMBER

PROJECT_NAME           = RandX
PROJECT_NUMBER         = 1.3.1
PROJECT_BRIEF          = "基于 xoshiro/xoroshiro 算法族的纯头文件伪随机数生成器库"

INPUT                  = RandX.hpp RandX_Cpp17.hpp README.md
OUTPUT_DIRECTORY       = docs/api
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
INPUT_ENCODING         = UTF-8
OUTPUT_LANGUAGE        = Chinese
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
QUIET                  = YES
RECURSIVE              = NO

# 预处理：预定义 C++23 特性宏，确保条件编译块全部解析
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = __cplusplus=202302L \
                         __cpp_char8_t=202002L \
                         __cpp_concepts=201907L \
                         __cpp_lib_ranges=202110L \
                         __cpp_lib_format=202207L \
                         __cpp_lib_span=202002L \
                         __cpp_lib_byteswap=202110L \
                         __cpp_consteval=202211L \
                         __cpp_constexpr_alloca=202406L

# 图表
HAVE_DOT               = YES
CALL_GRAPH             = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
DOT_GRAPH_MAX_NODES    = 50

# 搜索
SEARCHENGINE           = YES

# 使用 README 作为主页
USE_MDFILE_AS_MAINPAGE = README.md
